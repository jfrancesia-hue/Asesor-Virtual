# ============================================================
# Asesor Virtual — Frontend Environment Variables
# Copiá este archivo a .env.local y completá los valores
# ============================================================

# URL de la API backend (sin trailing slash)
# Desarrollo: http://localhost:3001/api
# Producción: https://api.asesorvirtual.com/api
NEXT_PUBLIC_API_URL=http://localhost:3001/api

