# ============================================================
# Asesor Virtual — Backend Environment Variables
# Copiá este archivo a .env y completá los valores
#
# ⚠️  El backend valida estas vars al arrancar (config/env.validation.ts)
# y rechaza valores placeholder. Si la validación falla, la app no levanta.
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
# Orígenes adicionales permitidos por CORS (separados por coma)
# EXTRA_ORIGINS=https://app.asesorvirtual.com

# ── JWT ──────────────────────────────────────────────────────
# Generá con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-super-secret-key-minimum-64-chars
# Access token corto + refresh token largo (httpOnly cookies)
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Supabase ─────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database → Connection Pooling → Transaction mode (para queries directas)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── IA — Claude (primario) ───────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Proveedor primario: 'anthropic' (recomendado) o 'openai' (fallback)
AI_PROVIDER=anthropic

# Modelos por asesor — claude-sonnet-4-6 para legal (razonamiento complejo),
# claude-haiku-4-5-20251001 para el resto (rápido y económico)
AI_MODEL_ANTHROPIC=claude-sonnet-4-6
CLAUDE_MODEL_LEGAL=claude-sonnet-4-6
CLAUDE_MODEL_HEALTH=claude-haiku-4-5-20251001
CLAUDE_MODEL_FINANCE=claude-haiku-4-5-20251001
CLAUDE_MODEL_PSYCHOLOGY=claude-haiku-4-5-20251001
CLAUDE_MODEL_HOME=claude-haiku-4-5-20251001

# Prompt caching — ahorra ~90% en tokens del sistema (recomendado: true)
CLAUDE_PROMPT_CACHE=true

# Máximo de mensajes del historial enviados a Claude (200K ctx → podemos subir hasta 100)
CLAUDE_MAX_HISTORY=50

# ── IA — OpenAI (fallback automático si Claude falla) ────────
# platform.openai.com → API Keys
OPENAI_API_KEY=sk-...
AI_MODEL_OPENAI=gpt-4o

# En producción es obligatorio aunque Anthropic sea el provider primario:
# se usa para embeddings del RAG legal.

# ── Mercado Pago (billing) ───────────────────────────────────
# developers.mercadopago.com → Tu app → Credenciales
# - APP_USR-... = Producción (cobra real)
# - TEST-...    = Sandbox
# Si no se setea, los endpoints de billing devuelven error en runtime
# y el resto del backend arranca normalmente.
MP_ACCESS_TOKEN=APP_USR-...

# Webhook signature secret — opcional pero recomendado en producción.
# developers.mercadopago.com → Tu app → Webhooks → "Clave secreta"
# Si está seteado, el backend verifica HMAC en cada notificación.
# MP_WEBHOOK_SECRET=

# URL pública del backend para que MP pueda llegar al webhook.
# En Render: https://tuasesor-api.onrender.com
# En desarrollo local: usá ngrok o similar para exponer localhost.
BACKEND_URL=http://localhost:3001

# Precios y planes están en código (billing.service.ts):
#   start       — ARS 44.900/mes
#   pro         — ARS 119.900/mes
#   enterprise  — ARS 299.000/mes
#   credits_10  — ARS 22.900   (10 créditos)
#   credits_30  — ARS 52.900   (30 créditos)
#   credits_100 — ARS 149.900  (100 créditos)

# ── Resend (email transaccional) ─────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM=noreply@asesorvirtual.com

# ── Rate limiting ────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ── Redis (opcional — para Bull queues) ──────────────────────
# REDIS_URL=redis://localhost:6379

# ── Sentry (monitoreo de errores) ────────────────────────────
# Obtené el DSN en https://sentry.io → Settings → Projects → Client Keys
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
